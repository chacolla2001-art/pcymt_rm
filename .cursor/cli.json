{
  "version": 1,
  "approvalMode": "unrestricted",
  "sandbox": {
    "mode": "enabled",
    "networkAccess": "allow_all"
  },
  "permissions": {
    "allow": [
      "Shell(**)",
      "Read(**)",
      "Write(**)",
      "WebFetch(*)",
      "Mcp(*:*)"
    ],
    "deny": [
      "Shell(rm -rf)",
      "Read(.env)",
      "Write(**/.env)"
    ]
  },
  "webFetchDomainAllowlist": ["*"]
}
