# =====================================
# PCyMT RM Backend — Variables de entorno
# Copiar a .env y completar valores reales
# =====================================

# --- Base de datos ---
# Local:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/pcymtrm_dev
# Supabase (conexión directa, recomendada para migraciones Sequelize):
# DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=

# Alternativa desglosada (si no usas DATABASE_URL):
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=pcymtrm_dev
# DB_USER=postgres
# DB_PASSWORD=
# DB_SSL=true

# --- Servidor ---
PORT=5000
NODE_ENV=development

# --- JWT (mínimo 64 caracteres) ---
JWT_SECRET=
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS ---
CORS_ORIGIN=http://localhost:4200

# --- Uploads ---
UPLOAD_DIR=../../shared/uploads
MAX_FILE_SIZE=52428800

# --- Seed (opcional) ---
# INITIAL_ADMIN_PASSWORD=tu_password_seguro

# --- Email (opcional) ---
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@pcymt.com
EMAIL_SERVICE=Gmail

# --- Google OAuth (opcional) ---
GOOGLE_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_MAPS_API_KEY=

# --- Supabase Storage (proxy /api/files en producción) ---
# URL del proyecto; si no se define, se deriva de SUPABASE_PROJECT_REF
SUPABASE_PROJECT_REF=fjypkthrwysjvcbdpgtq
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_STORAGE_BUCKET=uploads
# Opcional: solo si el bucket no es público
# SUPABASE_SERVICE_ROLE_KEY=

# --- Redis (opcional) ---
# REDIS_URL=

# --- Rate limiting ---
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100

# --- Logging ---
# LOG_LEVEL=info
