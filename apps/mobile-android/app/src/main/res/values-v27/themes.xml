<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.PedroChacolla" parent="Base.Theme.PedroChacolla">
        <!-- Transparent status bar for immersive header -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">?attr/isLightTheme</item>
        <!-- Opaque nav bar matching window background -->
        <item name="android:navigationBarColor">?android:attr/windowBackground</item>
        <!-- Light/dark nav bar icons depending on theme (API 27+) -->
        <item name="android:windowLightNavigationBar">?attr/isLightTheme</item>
    </style>
</resources>
