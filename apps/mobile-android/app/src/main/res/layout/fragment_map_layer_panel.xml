<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/background_dark"
    android:padding="16dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_rounded_dark" />

    <!-- Title row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Configuración del Mapa"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/panel_progress"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Public config status card -->
    <LinearLayout
        android:id="@+id/config_status_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_rounded_dark"
        android:padding="12dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tv_config_status_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mapa público guardado"
            android:textColor="#AAAAAA"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_config_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cargando..."
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_config_updated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#888888"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Load button — visible to everyone -->
    <Button
        android:id="@+id/btn_load_config"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cargar Mapa Público"
        android:layout_marginBottom="8dp"
        android:enabled="false" />

    <!-- Save button — admin only, shown/hidden in code -->
    <Button
        android:id="@+id/btn_save_config"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Guardar Mapa Actual como Público"
        android:textColor="#90CAF9"
        android:layout_marginBottom="8dp"
        android:visibility="gone" />

    <!-- Reset POI positions button — admin only -->
    <Button
        android:id="@+id/btn_reset_poi"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Restablecer posiciones de POIs"
        android:textColor="#888888"
        android:textSize="12sp"
        android:visibility="gone" />

</LinearLayout>
