<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.auth.EmailVerificationPendingFragment">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/background_game"
        android:scaleType="centerCrop"
        android:contentDescription="" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_game_overlay" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="48dp"
            android:paddingBottom="32dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <ImageView
                android:layout_width="150dp"
                android:layout_height="110dp"
                android:src="@drawable/logo_parque"
                android:scaleType="centerInside"
                android:contentDescription="Logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="VERIFICA TU CORREO"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:textColor="#FFFFFFFF"
                android:letterSpacing="0.08"
                android:shadowColor="#CC000000"
                android:shadowRadius="8"
                android:shadowDy="3" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_game_card"
                android:padding="16dp"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ACTIVA TU CUENTA"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#FFD9B992"
                    android:letterSpacing="0.06"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tv_verification_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.3"
                    android:layout_marginBottom="16dp"
                    tools:text="Enviamos un enlace de verificación a tu correo. Abre el mensaje, verifica tu cuenta y luego vuelve aquí para actualizar el estado." />

                <LinearLayout
                    android:id="@+id/btn_refresh_verification"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_btn_explorar"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YA VERIFIQUÉ, ACTUALIZAR"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"
                        android:textColor="#FFFFFFFF"
                        android:letterSpacing="0.06" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_resend_verification"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_btn_nav"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="REENVIAR CORREO"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFFFF"
                        android:letterSpacing="0.05" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_back_to_login"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="← Volver a Iniciar sesión"
                    android:textColor="#CCFFFFFF"
                    app:cornerRadius="8dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
