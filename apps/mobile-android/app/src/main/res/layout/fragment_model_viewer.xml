<?xml version="1.0" encoding="utf-8"?>
<!--
  fragment_model_viewer.xml — Visor 3D para el Modo Explorador.
  Rediseñado con la línea gráfica "estilo juego" del módulo Inicio:
  fondo background_game.jpg + gradiente oscuro + tarjetas bg_game_card.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ── CAPA 1: imagen de fondo del parque ─────────────────────── -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/background_game"
        android:scaleType="centerCrop"
        android:contentDescription="" />

    <!-- ── CAPA 2: gradiente oscuro (igual que módulo Inicio) ─────── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_game_overlay" />

    <!-- ── CAPA 3: SceneView 3D (fondo semi-oscuro para contraste) ── -->
    <FrameLayout
        android:id="@+id/modelViewerSceneContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#881A1A2E" />

    <!-- ── Overlay de carga del modelo ───────────────────────────── -->
    <FrameLayout
        android:id="@+id/modelViewerLoadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <ProgressBar
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:indeterminateTint="#FFD9B992" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Cargando modelo 3D…"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:shadowColor="#CC000000"
                android:shadowRadius="4" />
        </LinearLayout>
    </FrameLayout>

    <!-- ══════════════════════════════════════════════════════════════
         Panel inferior de información — estilo tarjeta de juego
         (misma estética que bg_game_card del módulo Inicio)
         ══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/modelViewerInfoCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bg_game_card"
        android:visibility="gone">

        <!-- ── Banner de estado: verde / naranja / oculto ─────────── -->
        <LinearLayout
            android:id="@+id/layoutModelViewerStatusBanner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="#E65100"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvModelViewerBannerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.06" />

        </LinearLayout>

        <!-- ── Contenido: nombre, info, botones ───────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="24dp">

            <!-- Handle bar -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_rounded_dark"
                android:alpha="0.7" />

            <!-- Nombre del animal — grande, negrita, blanco con sombra -->
            <TextView
                android:id="@+id/tvModelViewerAnimalName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:textColor="#FFFFFFFF"
                android:letterSpacing="0.02"
                android:shadowColor="#DD000000"
                android:shadowRadius="8"
                android:shadowDx="1"
                android:shadowDy="2" />

            <!-- Nombre científico — itálica, color beige arena -->
            <TextView
                android:id="@+id/tvModelViewerScientific"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="13sp"
                android:textStyle="italic"
                android:textColor="#FFD9B992"
                android:visibility="gone" />

            <!-- Chips: categoría + distancia -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipModelViewerCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone"
                    app:chipBackgroundColor="#40D9B992"
                    app:chipStrokeColor="#88D9B992"
                    app:chipStrokeWidth="1dp"
                    android:textColor="#FFFFFFFF"
                    style="@style/Widget.Material3.Chip.Suggestion" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipModelViewerDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    app:chipBackgroundColor="#40D9B992"
                    app:chipStrokeColor="#88D9B992"
                    app:chipStrokeWidth="1dp"
                    android:textColor="#FFFFFFFF"
                    style="@style/Widget.Material3.Chip.Suggestion" />

            </LinearLayout>

            <!-- Hábitat -->
            <TextView
                android:id="@+id/tvModelViewerHabitat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="13sp"
                android:textColor="#CCFFFFFF"
                android:visibility="gone" />

            <!-- Botones de acción -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <!-- Cerrar: contorno beige translúcido -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnModelViewerClose"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    android:text="Cerrar"
                    android:textSize="14sp"
                    android:textColor="#FFFFFFFF"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="#88D9B992"
                    app:cornerRadius="14dp" />

                <!-- Guardar: rojo arcilla, fuente negrita, estilo tarjeta juego -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnModelViewerSave"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="2"
                    android:text="¡Guardar encuentro!"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFFFF"
                    android:letterSpacing="0.02"
                    style="@style/Widget.Material3.Button"
                    app:backgroundTint="#FFA33B31"
                    app:cornerRadius="14dp" />

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ── FAB volver — esquina superior izquierda ────────────────── -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabModelViewerBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:contentDescription="Volver"
        android:src="@drawable/ic_arrow_back"
        app:backgroundTint="#C0150E05"
        app:tint="#FFD9B992"
        app:fabSize="mini"
        app:borderWidth="1dp" />

</FrameLayout>
