<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dashboard_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.dashboard.DashboardFragment">

    <!-- 2D map (park map with markers, sections and labels) -->
    <com.univalle.pedrochacolla.ui.dashboard.ParkMapView
        android:id="@+id/park_map_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Banner de advertencia: fuera de los límites del parque (visible en la parte superior) -->
    <TextView
        android:id="@+id/banner_out_of_bounds"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:background="#CCB71C1C"
        android:gravity="center"
        android:padding="10dp"
        android:text="🚨 Estás fuera de los límites del parque"
        android:textColor="#FFFFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />



    <!-- Botón Volver (top-left) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_back_home"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:contentDescription="Volver"
        android:src="@drawable/ic_arrow_back"
        app:fabSize="mini"
        app:backgroundTint="#AA000000"
        app:tint="#FFFFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Botón para centrar en ubicación del usuario (esquina inferior derecha) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_my_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:contentDescription="Mi ubicación"
        android:src="@android:drawable/ic_menu_mylocation"
        app:fabSize="mini"
        app:backgroundTint="#AA000000"
        app:tint="#FFFFFFFF"
        app:layout_constraintBottom_toTopOf="@id/btn_play_explorer"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Zoom out -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_zoom_out"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:contentDescription="Zoom menos"
        android:src="@drawable/ic_zoom_out"
        app:fabSize="mini"
        app:backgroundTint="#AA000000"
        app:tint="#FFFFFFFF"
        app:layout_constraintBottom_toTopOf="@id/btn_my_location"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Zoom in -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_zoom_in"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:contentDescription="Zoom más"
        android:src="@drawable/ic_zoom_in"
        app:fabSize="mini"
        app:backgroundTint="#AA000000"
        app:tint="#FFFFFFFF"
        app:layout_constraintBottom_toTopOf="@id/btn_zoom_out"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Spinner de carga GPS (misma posición que el FAB, visible mientras espera) -->
    <ProgressBar
        android:id="@+id/progress_gps"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/btn_play_explorer"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botón para cancelar navegación (esquina superior derecha) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_cancel_navigation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="Cancelar navegación"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:visibility="gone"
        app:fabSize="mini"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botón para mostrar/ocultar capa de POIs -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_toggle_poi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="Mostrar puntos de interés"
        android:src="@drawable/ic_layers"
        app:fabSize="mini"
        app:backgroundTint="#FFFFFF"
        app:tint="#666666"
        app:layout_constraintTop_toBottomOf="@id/btn_cancel_navigation"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botón para guardar/cargar capas del mapa -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_map_layers"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="Capas del mapa"
        android:src="@drawable/ic_save"
        app:fabSize="mini"
        app:backgroundTint="#FFFFFF"
        app:tint="#666666"
        app:layout_constraintTop_toBottomOf="@id/btn_toggle_poi"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botón inspector de coordenadas (oculto) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_coord_inspector"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="Inspector de coordenadas"
        android:src="@drawable/ic_pin_drop"
        android:visibility="gone"
        app:fabSize="mini"
        app:backgroundTint="#FFFFFF"
        app:tint="#666666"
        app:layout_constraintTop_toBottomOf="@id/btn_map_layers"
        app:layout_constraintEnd_toEndOf="parent" />



    <!-- Tarjeta deslizable desde arriba -->
    <androidx.cardview.widget.CardView
        android:id="@+id/top_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingVertical="12dp">

            <TextView
                android:id="@+id/card_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/white"
                android:text="Nombre del animal"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_navigate_to_anchor"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="12dp"
                android:paddingHorizontal="12dp"
                android:text="Ir"
                android:textAllCaps="false"
                style="@style/Widget.Material3.Button.TonalButton" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Botón JUGAR — mismo estilo que el card de explorar en la pantalla de inicio -->
    <LinearLayout
        android:id="@+id/btn_play_explorer"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_btn_explorar"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="4dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toTopOf="@id/icon_carousel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_explorer"
            android:scaleType="centerInside"
            android:contentDescription=""
            app:tint="#FFFFFFFF" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JUGAR"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:textColor="#FFFFFFFF"
                android:letterSpacing="0.08" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Busca animales en el parque"
                android:textSize="11sp"
                android:textColor="#DDF2C4BF" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶"
            android:textSize="22sp"
            android:textColor="#FFFFFFFF" />

    </LinearLayout>

    <!-- Carousel de iconos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/icon_carousel"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:background="@drawable/control_panel_bg"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:listitem="@layout/item_icon_carousel" />


</androidx.constraintlayout.widget.ConstraintLayout>
