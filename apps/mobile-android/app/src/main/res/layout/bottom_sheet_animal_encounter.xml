<?xml version="1.0" encoding="utf-8"?>
<!--
  bottom_sheet_animal_encounter.xml  — Pokedex full-screen modal
  ──────────────────────────────────────────────────────────────
  IDs requeridos por AnimalEncounterBottomSheet.kt:
    headerSection, cardEncounterIcon, ivEncounterIcon, sceneContainer3D,
    tvCapturedBadge, dividerInfoCard (GONE, compat), tvEncounterAnimalName,
    tvEncounterScientific, rowCategory, tvEncounterCategory, cellSection,
    tvSection, chipEncounterDistance, tvEncounterDistanceValue,
    rowHabitat, tvEncounterHabitat, tvEncounterRangeHint,
    btnSaveEncounter, btnGoToArMixto,
    btnViewIn3D (GONE ghost), chipEncounterStatus (GONE ghost)
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="false">

    <!-- ══════════════════════════════════════════════════════
         HERO — visor 3D, ocupa toda la mitad superior
         El gradiente de sección lo aplica Kotlin.
         ══════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/headerSection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="true"
        android:clipToPadding="true"
        android:background="#FF070D07">

        <!-- Fallback 2D: imagen del animal centered, sin card circular -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEncounterIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="#00000000">

            <ImageView
                android:id="@+id/ivEncounterIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:padding="32dp"
                android:contentDescription="Animal"
                android:src="@drawable/ic_profile_placeholder" />

        </com.google.android.material.card.MaterialCardView>

        <!-- SceneView 3D — reemplaza al icono cuando carga el GLB -->
        <FrameLayout
            android:id="@+id/sceneContainer3D"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <!-- Gradiente inferior: funde el hero con el panel de info -->
        <View
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_encounter_image_overlay" />

        <!-- Botón cerrar — esquina superior izquierda -->
        <ImageButton
            android:id="@+id/btnCloseSheet"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="top|start"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/bg_back_circle"
            android:src="@drawable/ic_close"
            android:contentDescription="Cerrar"
            android:tint="#FFFFFFFF"
            android:padding="10dp"
            android:elevation="10dp" />

        <!-- Badge CAPTURADO — esquina superior derecha -->
        <TextView
            android:id="@+id/tvCapturedBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_captured_badge"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"
            android:text="CAPTURADO"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:fontFamily="sans-serif-black"
            android:textColor="#FF34C759"
            android:elevation="10dp"
            android:visibility="gone" />

    </FrameLayout>

    <!-- ══════════════════════════════════════════════════════
         PANEL INFERIOR — info + botones
         Background liso sin esquinas redondeadas: continuidad visual con el hero.
         ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FF070D07">

        <!-- Handle de arrastre -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="4dp"
            android:background="#40FFFFFF" />

        <!-- Nombre del animal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="4dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/tvEncounterAnimalName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="32sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:textColor="#FFFFFFFF"
                android:letterSpacing="0.01"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Perro Criollo" />

            <TextView
                android:id="@+id/tvEncounterScientific"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="14sp"
                android:textStyle="italic"
                android:textColor="#CCE8D5BC"
                android:visibility="gone"
                tools:text="Canis lupus familiaris"
                tools:visibility="visible" />

        </LinearLayout>

        <!-- dividerInfoCard: ghost, Kotlin lo referencia para color de seccion -->
        <View
            android:id="@+id/dividerInfoCard"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="gone" />

        <!-- ── Fila de 3 chips: Tipo | Zona | Distancia ──────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp">

            <!-- Tipo -->
            <LinearLayout
                android:id="@+id/rowCategory"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_chip"
                android:layout_marginEnd="6dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvEncounterCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:textColor="#FFFFFFFF"
                    android:gravity="center"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="Mamifero" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="TIPO"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:textColor="#B3FFFFFF" />

            </LinearLayout>

            <!-- Zona -->
            <LinearLayout
                android:id="@+id/cellSection"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_chip"
                android:layout_marginEnd="6dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvSection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:textColor="#FFFFFFFF"
                    android:gravity="center"
                    android:maxLines="2"
                    android:ellipsize="end"
                    tools:text="Tierras Bajas" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="ZONA"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:textColor="#B3FFFFFF" />

            </LinearLayout>

            <!-- Distancia -->
            <LinearLayout
                android:id="@+id/chipEncounterDistance"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_chip"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvEncounterDistanceValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:textColor="#FFFFFFFF"
                    android:gravity="center"
                    android:maxLines="1"
                    tools:text="145 m" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="DISTANCIA"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:textColor="#B3FFFFFF" />

            </LinearLayout>

        </LinearLayout>

        <!-- ── Fila Habitat ──────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/rowHabitat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_stat_chip"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HABITAT"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textColor="#FFD9B992" />

            <TextView
                android:id="@+id/tvEncounterHabitat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:textSize="13sp"
                android:textColor="#FFFFFFFF"
                android:gravity="end"
                android:maxLines="2"
                android:ellipsize="end"
                tools:text="Bosques y montanas" />

        </LinearLayout>

        <!-- ── Aviso de rango ────────────────────────────────── -->
        <TextView
            android:id="@+id/tvEncounterRangeHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="4dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/bg_stat_chip"
            android:gravity="center"
            android:textSize="12sp"
            android:textColor="#FFFFB74D"
            android:letterSpacing="0.02"
            android:visibility="gone"
            tools:text="Debes estar a menos de 50 m del animal para guardar"
            tools:visibility="visible" />

        <!-- ── Botones ───────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="28dp">

            <!-- Guardar encuentro -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveEncounter"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Guardar encuentro"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.04"
                android:textAllCaps="false"
                android:enabled="false"
                android:textColor="#FFFFFFFF"
                app:backgroundTint="#FFA33B31"
                app:strokeColor="#FFF2C4BF"
                app:strokeWidth="1dp"
                app:cornerRadius="28dp"
                app:icon="@drawable/ic_save"
                app:iconSize="20dp"
                app:iconTint="#FFFFFFFF"
                app:iconGravity="textStart"
                app:iconPadding="8dp" />

            <!-- Ver en Realidad Mixta -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoToArMixto"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:text="Ver en Realidad Mixta"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:textColor="#FFFFFFFF"
                app:cornerRadius="26dp"
                app:strokeWidth="1dp"
                app:strokeColor="#88FFFFFF"
                app:icon="@drawable/ic_view_3d"
                app:iconSize="20dp"
                app:iconTint="#FFFFFFFF"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

    <!-- Ghost IDs requeridos por Kotlin -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnViewIn3D"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <com.google.android.material.chip.Chip
        android:id="@+id/chipEncounterStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

</LinearLayout>
