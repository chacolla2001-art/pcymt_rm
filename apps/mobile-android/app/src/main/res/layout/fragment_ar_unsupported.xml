<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_ar_unsupported"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Realidad Aumentada"
            app:titleTextColor="?attr/colorOnSurface"
            app:navigationIcon="@drawable/ic_home_black_24dp"
            app:navigationIconTint="?attr/colorOnSurface" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="32dp">

            <!-- Spacer -->
            <View
                android:layout_width="1dp"
                android:layout_height="48dp" />

            <!-- Icon -->
            <ImageView
                android:id="@+id/iv_ar_unsupported_icon"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/icon_camera"
                android:alpha="0.3"
                android:importantForAccessibility="no" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp" />

            <!-- Title -->
            <TextView
                android:id="@+id/tv_ar_unsupported_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ar_unsupported_title"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="?attr/colorOnSurface"
                android:textAlignment="center" />

            <View
                android:layout_width="1dp"
                android:layout_height="16dp" />

            <!-- Reason message (set dynamically) -->
            <TextView
                android:id="@+id/tv_ar_unsupported_reason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ar_unsupported_reason_default"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textAlignment="center"
                android:lineSpacingMultiplier="1.3" />

            <View
                android:layout_width="1dp"
                android:layout_height="32dp" />

            <!-- Info card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant"
                style="@style/Widget.Material3.CardView.Outlined">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ar_unsupported_requirements_title"
                        android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textColor="?attr/colorOnSurface" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/ar_unsupported_requirements_list"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:lineSpacingMultiplier="1.5" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="1dp"
                android:layout_height="24dp" />

            <!-- Device info card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                style="@style/Widget.Material3.CardView.Filled">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ar_unsupported_device_info"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="8dp" />

                    <TextView
                        android:id="@+id/tv_ar_device_details"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="1dp"
                android:layout_height="24dp" />

            <!-- Return button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ar_unsupported_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ar_unsupported_back"
                style="@style/Widget.Material3.Button.TonalButton" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
