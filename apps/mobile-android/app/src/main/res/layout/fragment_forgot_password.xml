<?xml version="1.0" encoding="utf-8"?>
<!--
    ╔══════════════════════════════════════════════════════════════╗
    ║  PANTALLA RECUPERAR CONTRASEÑA — ESTILO JUEGO               ║
    ║  Misma línea gráfica que la pantalla de inicio/login        ║
    ╚══════════════════════════════════════════════════════════════╝
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.auth.ForgotPasswordFragment">

    <!-- Fondo del parque -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/background_game"
        android:scaleType="centerCrop"
        android:contentDescription="" />

    <!-- Gradiente overlay oscuro -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_game_overlay" />

    <!-- Contenido scrollable -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="40dp"
            android:paddingBottom="32dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- ══ Logo ══ -->
            <ImageView
                android:layout_width="150dp"
                android:layout_height="110dp"
                android:src="@drawable/logo_parque"
                android:scaleType="centerInside"
                android:contentDescription="Logo" />

            <!-- ══ Título del juego ══ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="JUKU GO"
                android:textSize="36sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:textColor="#FFFFFFFF"
                android:letterSpacing="0.10"
                android:shadowColor="#DD000000"
                android:shadowRadius="10"
                android:shadowDx="2"
                android:shadowDy="3" />

            <!-- Subtítulo parque -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="24dp"
                android:text="PARQUE DE LAS CULTURAS Y LA MADRE TIERRA"
                android:textSize="9sp"
                android:textColor="#FFFFFFFF"
                android:fontFamily="sans-serif"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:gravity="center" />

            <!-- ══ CARD: Formulario de recuperación ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_game_card"
                android:padding="16dp"
                android:layout_marginBottom="10dp">

                <!-- Ícono + Heading -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RECUPERAR CONTRASEÑA"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"
                        android:textColor="#FFD9B992"
                        android:letterSpacing="0.06" />
                </LinearLayout>

                <!-- Descripción -->
                <TextView
                    android:id="@+id/tv_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:text="Ingresa tu correo y te enviaremos una contraseña temporal."
                    android:textSize="13sp"
                    android:textColor="#AAFFFFFF"
                    android:lineSpacingMultiplier="1.3" />

                <!-- Campo de correo -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_forgot_email"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:hint="Correo electrónico"
                    app:hintTextColor="#AAFFFFFF"
                    android:theme="@style/ThemeOverlay.App.TextInput.Dark"
                    app:boxStrokeColor="#66FFFFFF"
                    app:boxStrokeWidth="1dp"
                    android:textColorHint="@color/white"
                    app:boxBackgroundColor="#22FFFFFF">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_forgot_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionDone"
                        android:textColor="#FFFFFFFF"
                        android:textColorHint="#88FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Botón Enviar -->
                <LinearLayout
                    android:id="@+id/btn_send_recovery"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_btn_explorar"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ENVIAR CONTRASEÑA"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"
                        android:textColor="#FFFFFFFF"
                        android:letterSpacing="0.08" />

                </LinearLayout>

                <!-- Volver al login -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_back_to_login"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="6dp"
                    android:text="← Volver a Iniciar sesión"
                    android:textSize="12sp"
                    android:textColor="#CCFFFFFF"
                    app:cornerRadius="8dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</FrameLayout>
