<?xml version="1.0" encoding="utf-8"?>
<!--
    Item del carrusel de animales en la pantalla de mapa.
    Mismo estilo que la colección: ícono + etiqueta de nombre.
    Gris/transparente = no capturado, color completo = capturado.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:gravity="center"
    android:layout_width="76dp"
    android:layout_height="match_parent"
    android:padding="4dp">

    <ImageView
        android:id="@+id/ivIcon"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:scaleType="centerCrop"
        android:contentDescription="@string/animal_model_icon" />

    <TextView
        android:id="@+id/tvIconLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Animal"
        android:textStyle="bold"
        android:textSize="9sp"
        android:ellipsize="end"
        android:maxLines="1"
        android:gravity="center"
        android:textColor="#FFFFFFFF" />

</LinearLayout>
