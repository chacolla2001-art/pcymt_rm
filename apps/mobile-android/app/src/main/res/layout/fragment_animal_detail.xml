<?xml version="1.0" encoding="utf-8"?>
<!--
  fragment_animal_detail.xml — "DEXCARD" — Rediseño explorador de fauna.

  Capas (fondo → frente):
    1. Foto de fondo del parque  (background_game)
    2. Gradiente oscuro           (gradient_game_overlay)
    3. SceneView 3D               (adSceneContainer — FrameLayout)
    4. Overlay de carga           (adLoadingOverlay)
    5. HUD superior               (back FAB + nº Pokédex + badge capturado)
    6. Panel de ficha inferior    (adInfoPanel — LinearLayout)

  — La aureola radial de color de sección se inserta programáticamente
    como primer hijo de adSceneContainer desde AnimalDetailFragment.
  — Todos los IDs son los mismos que en la versión anterior para
    máxima compatibilidad con AnimalDetailFragment.kt sin cambios.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ══════════════════════════════════════════════════════
         CAPA 1 — Fotografía de fondo del parque
         ══════════════════════════════════════════════════════ -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/background_game"
        android:scaleType="centerCrop"
        android:contentDescription="" />

    <!-- ══════════════════════════════════════════════════════
         CAPA 2 — Degradado oscuro dramático
         ══════════════════════════════════════════════════════ -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_game_overlay" />

    <!-- ══════════════════════════════════════════════════════
         CAPA 3 — Contenedor SceneView 3D
         La aureola radial de sección se inserta desde Kotlin
         como primer hijo, antes del SceneView.
         ══════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/adSceneContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#70000C1A" />

    <!-- ══════════════════════════════════════════════════════
         CAPA 4 — Overlay de carga del modelo 3D
         ══════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/adLoadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E0000813">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Anillo de carga -->
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_loading_circle">

                <ProgressBar
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:indeterminateTint="#FFD9B992" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Preparando escena…"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.06" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Cargando modelo 3D"
                android:textColor="#66D9B992"
                android:textSize="11sp"
                android:letterSpacing="0.04" />

        </LinearLayout>
    </FrameLayout>

    <!-- ══════════════════════════════════════════════════════
         CAPA 5 — HUD SUPERIOR
         Tres elementos flotantes independientes:
           • FAB atrás (izquierda)
           • Nº Pokédex (derecha)
           • Badge CAPTURADO (centro)
         ══════════════════════════════════════════════════════ -->

    <!-- FAB de regreso — esquina superior izquierda -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/adFabBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:contentDescription="Volver"
        android:src="@drawable/ic_arrow_back"
        app:backgroundTint="#CC050F14"
        app:tint="#FFD9B992"
        app:fabSize="mini"
        app:borderWidth="0dp"
        app:strokeColor="#55D9B992"
        app:strokeWidth="1dp"
        android:elevation="10dp" />

    <!-- Número de registro estilo Pokédex — esquina superior derecha -->
    <TextView
        android:id="@+id/adDisplayOrder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="16dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="7dp"
        android:paddingBottom="7dp"
        android:background="@drawable/bg_pill_surface"
        android:textColor="#BFD9B992"
        android:textSize="13sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-condensed"
        android:letterSpacing="0.08"
        android:elevation="8dp"
        android:visibility="gone"
        tools:text="Nº 001"
        tools:visibility="visible" />

    <!-- Badge CAPTURADO — parte superior centrada -->
    <LinearLayout
        android:id="@+id/adCapturedBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="7dp"
        android:paddingBottom="7dp"
        android:background="@drawable/bg_captured_badge"
        android:visibility="gone"
        android:elevation="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦  CAPTURADO"
            android:textColor="#FF34C759"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:fontFamily="sans-serif-black" />
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════
         CAPA 6 — PANEL DE FICHA "DEXCARD"
         Anclado al borde inferior. Oculto hasta que el modelo
         3D termina de cargar (AnimalDetailFragment lo muestra).

         Estructura interna:
           ① Tira de color de sección  (adAccentBar)
           ② Handle pill
           ③ Nombre + nombre científico
           ④ Celdas de stats: Tipo | Zona | Distancia
           ⑤ Chip de hábitat (full-width)
           ⑥ adBadgeRow oculto (compat. Kotlin — IDs reales en ④)
           ⑦ Aviso de rango
           ⑧ Botones de acción
         ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/adInfoPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bg_animal_detail_panel"
        android:visibility="gone"
        android:elevation="6dp">

        <!-- ① Tira de acento de sección — coloreada desde Kotlin -->
        <View
            android:id="@+id/adAccentBar"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="#FFD9B992" />

        <!-- ② Handle de arrastre -->
        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="2dp"
            android:background="#55FFFFFF"
            android:alpha="0.7" />

        <!-- ═══════════════════════════════════════════════════
             ③ NOMBRE + NOMBRE CIENTÍFICO
             ═══════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="14dp">

            <TextView
                android:id="@+id/adAnimalName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="30sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:textColor="#FFFFFFFF"
                android:letterSpacing="0.01"
                android:lineSpacingMultiplier="1.05"
                android:shadowColor="#DD000000"
                android:shadowRadius="10"
                android:shadowDx="0"
                android:shadowDy="2"
                android:maxLines="2"
                android:ellipsize="end"
                tools:text="Oso Andino" />

            <TextView
                android:id="@+id/adScientificName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textSize="13sp"
                android:textStyle="italic"
                android:textColor="#BFD9B992"
                android:letterSpacing="0.01"
                android:visibility="gone"
                tools:text="Tremarctos ornatus"
                tools:visibility="visible" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════
             ④ CELDAS DE STATS — Tipo | Zona | Distancia
             Cada celda tiene bg_pill_surface individual.
             Los valores (adBadgeCategory / adBadgeSection /
             adBadgeDistance) son coloreados desde Kotlin.
             ═══════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="10dp">

            <!-- Celda: Tipo / Categoría -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="66dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_pill_surface"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:layout_marginEnd="5dp">

                <TextView
                    android:id="@+id/adBadgeCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:textColor="#FFFFFFFF"
                    android:gravity="center"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:visibility="gone"
                    tools:text="Mamífero"
                    tools:visibility="visible" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Tipo"
                    android:textSize="10sp"
                    android:letterSpacing="0.06"
                    android:textColor="#66FFFFFF" />

            </LinearLayout>

            <!-- Celda: Zona / Sección -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="66dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_pill_surface"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:layout_marginEnd="5dp">

                <TextView
                    android:id="@+id/adBadgeSection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:textColor="#FFFFFFFF"
                    android:gravity="center"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:visibility="gone"
                    tools:text="T. Altas"
                    tools:visibility="visible" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Zona"
                    android:textSize="10sp"
                    android:letterSpacing="0.06"
                    android:textColor="#66FFFFFF" />

            </LinearLayout>

            <!-- Celda: Distancia -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="66dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_pill_surface"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp">

                <TextView
                    android:id="@+id/adBadgeDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:textColor="#FFFFFFFF"
                    android:gravity="center"
                    android:maxLines="1"
                    android:visibility="gone"
                    tools:text="42 m"
                    tools:visibility="visible" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Distancia"
                    android:textSize="10sp"
                    android:letterSpacing="0.06"
                    android:textColor="#66FFFFFF" />

            </LinearLayout>

        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════
             ⑤ CHIP DE HÁBITAT — full-width, bg_pill_surface
             ═══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/adHabitatRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_pill_surface"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="11dp"
            android:paddingBottom="11dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌿"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Hábitat"
                android:textColor="#99D9B992"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.06" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/adHabitatValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2.2"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:gravity="end"
                android:maxLines="2"
                android:ellipsize="end"
                tools:text="Bosques andinos entre 1 800 y 4 700 m s.n.m." />

        </LinearLayout>

        <!-- ⑥ Badge row fantasma — conserva los IDs para compatibilidad
             con styleBadge() de Kotlin. Los IDs reales que muestran
             datos están en las celdas ④ de arriba. -->
        <LinearLayout
            android:id="@+id/adBadgeRow"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="horizontal"
            android:visibility="gone" />

        <!-- ═══════════════════════════════════════════════════
             ⑦ AVISO DE RANGO — aparece si fuera de alcance
             ═══════════════════════════════════════════════════ -->
        <TextView
            android:id="@+id/adRangeHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="8dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:background="@drawable/bg_pill_surface"
            android:textColor="#FFFFB74D"
            android:textSize="12sp"
            android:gravity="center"
            android:letterSpacing="0.02"
            android:visibility="gone"
            tools:text="📍 Acércate a menos de 50 m para guardar el encuentro"
            tools:visibility="visible" />

        <!-- ═══════════════════════════════════════════════════
             ⑧ BOTONES DE ACCIÓN
             ═══════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="28dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#20D9B992"
                android:layout_marginBottom="14dp" />

            <!-- PRIMARIO: pill roja full-width -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/adBtnSave"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="⭐  Guardar encuentro"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.02"
                android:textAllCaps="false"
                android:textColor="#FFFFFFFF"
                app:backgroundTint="#FFA33B31"
                app:strokeColor="#FFF2C4BF"
                app:strokeWidth="1dp"
                app:cornerRadius="27dp"
                android:elevation="4dp" />

            <!-- SECUNDARIO: outline discreto -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/adBtnClose"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:text="Cerrar"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:textColor="#99FFFFFF"
                app:strokeColor="#33D9B992"
                app:strokeWidth="1dp"
                app:cornerRadius="23dp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
