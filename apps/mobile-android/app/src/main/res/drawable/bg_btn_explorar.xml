<?xml version="1.0" encoding="utf-8"?>
<!-- Main CTA "EXPLORAR" button — Rojo Arcilla with salmon border, pressed = darker -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#FF6B2017" />
            <corners android:radius="14dp" />
            <stroke android:width="2dp" android:color="#FFF2C4BF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFA33B31" />
            <corners android:radius="14dp" />
            <stroke android:width="2dp" android:color="#FFF2C4BF" />
        </shape>
    </item>
</selector>
