<?xml version="1.0" encoding="utf-8"?>
<!--
  bg_animal_detail_panel.xml
  Fondo del panel inferior en la pantalla de detalle del animal.
  Tarjeta oscura translúcida con esquinas redondeadas solo en la parte
  superior, borde sutil en tono beige dorado — línea gráfica de la app.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#EE070D07" />
    <corners
        android:topLeftRadius="28dp"
        android:topRightRadius="28dp"
        android:bottomLeftRadius="0dp"
        android:bottomRightRadius="0dp" />
    <stroke
        android:width="1dp"
        android:color="#33D9B992" />
</shape>
